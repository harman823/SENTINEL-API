{
    "name": "autoapi-vscode",
    "displayName": "AutoAPI Intelligence",
    "description": "Run AutoAPI Intelligence directly from VS Code",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "autoapi.runAnalysis",
                "title": "AutoAPI: Run Analysis on Current File"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "18.x",
        "typescript": "^5.1.3"
    },
    "dependencies": {
        "axios": "^1.6.0"
    }
}