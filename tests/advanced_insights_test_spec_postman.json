    },
    {
      "name": "Data Export (exposes PII in response)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/data/export",
          "host": ["{{base_url}}"],
          "path": ["data", "export"]
        }
      }
    }
  ]
